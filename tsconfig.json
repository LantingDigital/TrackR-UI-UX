{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "expo-ahap": [
        "src/types/expo-ahap"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "src/_legacy",
    "src/_v2",
    "src/features/parks/map/_mapbox",
    "node_modules/expo-ahap/**/*",
    "functions"
  ]
}
