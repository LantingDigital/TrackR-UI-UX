{
  "mcpServers": {
    "nanobanana": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--browser", "chrome",
        "--user-data-dir", "./mcp-data/nanobanana"
      ]
    },
    "article": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--browser", "chrome",
        "--user-data-dir", "./mcp-data/article"
      ]
    }
  }
}
